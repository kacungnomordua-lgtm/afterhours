# Discord Bot Configuration
TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here

# Remove.bg API Configuration
# Get free API key at: https://www.remove.bg/api
# Free plan: 50 API calls per month
REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# One Word Story Game Configuration
# Channel IDs for story game (comma-separated)
# Example: 123456789,987654321
STORY_CHANNELS=your_story_channel_ids_here

# One Word Story Settings
MIN_WORDS_FOR_COMPLETION=3
MAX_WORDS_PER_STORY=20

# Optional: OpenAI API for better AI ratings
# Leave empty to use rule-based rating
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

